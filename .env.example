# ==================== AI 模型配置 ====================
# DeepSeek API（云端）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama 本地模型
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2:7b

# 模型路由模式: local_first / cloud_first / local_only / cloud_only
ROUTER_MODE=local_first

# 备用 API（可选，OpenAI 兼容接口）
# FALLBACK_API_KEY=
# FALLBACK_BASE_URL=
# FALLBACK_MODEL=gpt-3.5-turbo

# ==================== 服务配置 ====================
# 本地助手 Web 端口
LOCAL_PORT=8080

# 云端 Brain 地址（保持 Agent 串联）
BRAIN_URL=http://localhost:5000
ENABLE_BRAIN_AGENT=true

# ==================== QQ Bot 配置 ====================
QQ_BOT_ENABLED=false
QQ_WS_URL=ws://localhost:3001

# ==================== 微信 Bot 配置 ====================
WECHAT_ENABLED=false
WECOM_BOT_KEY=

# ==================== Telegram Bot 配置 ====================
# TELEGRAM_BOT_TOKEN=your-bot-token

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
