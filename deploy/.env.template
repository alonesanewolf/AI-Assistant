# ============================================
# AI_Assistant 云服务器环境配置模板
# 复制为 .env 并填写实际值
# ============================================

# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI 助手配置
HOST=0.0.0.0
PORT=8080
APP_PREFIX=/ai
AGENT_NAME=CloudServer

# 路由模式: local_first / cloud_first / local_only / cloud_only
ROUTER_MODE=cloud_only

# 云端 Brain
ENABLE_BRAIN_AGENT=false
BRAIN_URL=http://localhost:5000

# ============================================
# 网络安全助手 (NetSec) 配置
# ============================================

# MySQL 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=YourMySQLPassword123!
MYSQL_DB=netsec_platform

# Flask 密钥（生产环境请生成随机字符串）
FLASK_SECRET_KEY=change-me-to-a-random-string-in-production

# NetSec 运行配置
NETSEC_PORT=5100
NETSEC_DEBUG=false
NETSEC_APP_ROOT=/netsec
NETSEC_HOST=0.0.0.0

# NetSec 管理员默认密码
DEFAULT_ADMIN_PASSWORD=Admin@123456
